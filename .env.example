# ============================================================
# TrueServe — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Ask Leon for the actual credentials.
#
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the
# browser. Everything else is server-only.
# ============================================================


# ------------------------------------------------------------
# Supabase (REQUIRED — app will not work without these)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_ACCESS_TOKEN=your-access-token-here


# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
APP_URL=http://localhost:3000


# ------------------------------------------------------------
# Stripe (payments)
# ------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ------------------------------------------------------------
# Square POS integration
# ------------------------------------------------------------
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key


# ------------------------------------------------------------
# Toast POS integration
# ------------------------------------------------------------
TOAST_CLIENT_SECRET=your-toast-client-secret


# ------------------------------------------------------------
# SMS / Phone verification (Twilio — primary)
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...


# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@trueservedelivery.com


# ------------------------------------------------------------
# Maps
# ------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
MAPBOX_ACCESS_TOKEN=pk.eyJ1...
MAPBOX_USERNAME=your-mapbox-username


# ------------------------------------------------------------
# GoHighLevel (CRM / workflows)
# ------------------------------------------------------------
GHL_API_KEY=
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_CUSTOMER_WORKFLOW_ID=
GHL_DRIVER_WORKFLOW_ID=
GHL_MERCHANT_WORKFLOW_ID=


# ------------------------------------------------------------
# Analytics / Feature flags
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
LAUNCHDARKLY_SDK_KEY=


# ------------------------------------------------------------
# Cron jobs
# ------------------------------------------------------------
CRON_SECRET=a-long-random-secret-string


# ------------------------------------------------------------
# Admin credentials (local dev only)
# ------------------------------------------------------------
ADMIN_EMAIL=admin@trueserve.dev
ADMIN_PASSWORD=


# ------------------------------------------------------------
# Optional / third-party integrations
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
# ClickUp (replaces Asana for task management)
CLICKUP_API_TOKEN=pk_...
CLICKUP_TEAM_ID=
CLICKUP_SPACE_ID=
CLICKUP_LIST_ID=

JIRA_API_TOKEN=
JIRA_DOMAIN=
JIRA_PROJECT_KEY=
JIRA_USER_EMAIL=
RESEND_API_KEY=
